rules_version = '2';

// Baseline rules. Tighten before production.
// Today: any signed-in user may read/write leads, and deletes are blocked outright
// (leads are retained indefinitely — see the data model). When this becomes multi-studio,
// scope access by request.auth's locationId / tenant claim.
service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      allow read, write: if request.auth != null;
      allow delete: if false; // never delete leads
    }
  }
}
